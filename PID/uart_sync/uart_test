#include "i2c_api.h"
#include "debug_uart.h"
#include <stdio.h>
#include <stdlib.h>
#include <stdint.h>
#include <math.h>
#include "config.h"

// --- CONFIGURATION ---
#define SYSTEM_FREQ        40000000 
#define TARGET_BAUD        115200
#define ISM_ADDR           0x6B
#define MMC_ADDR           0x30

#define RAD2DEG            57.295779f
#define DEG2RAD            0.0174533f

/* UART Register Mapping */
#define UART0_BASE 0x10000100
#define UART2_BASE 0x10000300
#define UART_REG(base, off) (*(volatile uint32_t *)(base + off))

#define REG_DATA   0x00
#define REG_LSR    0x14
#define REG_DLL    0x00
#define REG_DLM    0x04
#define REG_IER    0x04
#define REG_FCR    0x08
#define REG_LCR    0x0C

/* --- MAHONY STATE --- */
float q[4] = {1.0f, 0.0f, 0.0f, 0.0f};
float Kp = 2.0f;
float Ki = 0.05f;
float exInt = 0, eyInt = 0, ezInt = 0;
float dt = 0.04f; // Loop timing constant

// Communication Buffers
char rx_buffer[64];
int rx_idx = 0;
char msg_out[128];

/**
 * Robust Hardware Initialization
 */
void uart_init_hw(uint32_t base, uint32_t baud) {
    uint32_t divisor = SYSTEM_FREQ / (16 * baud);
    UART_REG(base, REG_IER) = 0x00;
    UART_REG(base, REG_LCR) = 0x83; // DLAB Enable
    UART_REG(base, REG_DLL) = divisor & 0xFF;
    UART_REG(base, REG_DLM) = (divisor >> 8) & 0xFF;
    UART_REG(base, REG_LCR) = 0x03; // 8N1
    UART_REG(base, REG_FCR) = 0x07; // FIFO Enable
}

void uart2_print(char *str) {
    while (*str) {
        while (!(UART_REG(UART2_BASE, REG_LSR) & 0x20));
        UART_REG(UART2_BASE, REG_DATA) = *str++;
    }
}

void write_reg(unsigned char addr, unsigned char reg, unsigned char val) {
    i2c_beginTransmission(addr);
    i2c_write(reg);
    i2c_write(val);
    i2c_endTransmission(1);
}

void normalize_quat() {
    float norm = sqrtf(q[0]*q[0] + q[1]*q[1] + q[2]*q[2] + q[3]*q[3]);
    if(norm == 0) return;
    q[0] /= norm; q[1] /= norm; q[2] /= norm; q[3] /= norm;
}

int main() {
    // 1. Hardware Setup
    uart_init_hw(UART0_BASE, TARGET_BAUD);
    uart_init_hw(UART2_BASE, TARGET_BAUD);
    i2c_init(0); 

    printf("\r\n--- Duplex Mahony AHRS Link Active ---\r\n");

    // 2. Sensor Initialization
    write_reg(ISM_ADDR, 0x10, 0x60); // Accel 416Hz
    write_reg(ISM_ADDR, 0x11, 0x60); // Gyro 416Hz
    write_reg(MMC_ADDR, 0x09, 0x10); // Mag Reset
    for(volatile int i=0; i<500000; i++);

    while (1) {
        // --- 3. RECEIVE FROM ESP32 (Non-blocking) ---
        if (UART_REG(UART2_BASE, REG_LSR) & 0x01) {
            char c = (char)(UART_REG(UART2_BASE, REG_DATA) & 0xFF);
            
            // Echo raw char to PC Terminal (UART0) with fixed formatting
            while (!(UART_REG(UART0_BASE, REG_LSR) & 0x20)); 
            UART_REG(UART0_BASE, REG_DATA) = c;
            if (c == '\n') { // Ensure newline on PC moves cursor to start
                while (!(UART_REG(UART0_BASE, REG_LSR) & 0x20)); 
                UART_REG(UART0_BASE, REG_DATA) = '\r';
            }

            if (c == '\n' || c == '\r') {
                if (rx_idx > 0) {
                    rx_buffer[rx_idx] = '\0';
                    // Dynamic tuning via ESP32
                    if (rx_buffer[0] == 'P' || rx_buffer[0] == 'I' || rx_buffer[0] == 'D') {
                        if (rx_buffer[0] == 'P') Kp = atof(&rx_buffer[1]);
                        if (rx_buffer[0] == 'I') Ki = atof(&rx_buffer[1]);
                        printf("\r\n>> GAIN UPDATE: Kp=%.2f, Ki=%.2f\r\n", Kp, Ki);
                    }
                    rx_idx = 0;
                }
            } else if (rx_idx < 63 && c >= 32) {
                rx_buffer[rx_idx++] = c;
            }
        }

        // --- 4. SENSOR ACQUISITION ---
        uint8_t buf[12];
        i2c_beginTransmission(ISM_ADDR);
        i2c_write(0x22); 
        i2c_endTransmission(1);
        
        int16_t gx=0, gy=0, gz=0, ax=0, ay=0, az=0;
        if (i2c_requestFrom(ISM_ADDR, 12, 1)) {
            for(int i=0; i<12; i++) buf[i] = i2c_read();
            gx = (int16_t)(buf[1] << 8 | buf[0]);
            gy = (int16_t)(buf[3] << 8 | buf[2]);
            gz = (int16_t)(buf[5] << 8 | buf[4]);
            ax = (int16_t)(buf[7] << 8 | buf[6]);
            ay = (int16_t)(buf[9] << 8 | buf[8]);
            az = (int16_t)(buf[11] << 8 | buf[10]);
        }

        // Mag Trigger
        write_reg(MMC_ADDR, 0x09, 0x01); 
        unsigned char status = 0;
        int timeout = 500; 
        while (!(status & 0x01) && timeout-- > 0) {
            i2c_beginTransmission(MMC_ADDR);
            i2c_write(0x08); i2c_endTransmission(1);
            i2c_requestFrom(MMC_ADDR, 1, 1);
            status = i2c_read();
        }

        float mx=0, my=0, mz=0;
        if (timeout > 0) {
            i2c_beginTransmission(MMC_ADDR);
            i2c_write(0x00); i2c_endTransmission(1);
            if (i2c_requestFrom(MMC_ADDR, 6, 1)) {
                uint8_t mlx = i2c_read(); uint8_t mmx = i2c_read();
                uint8_t mly = i2c_read(); uint8_t mmy = i2c_read();
                uint8_t mlz = i2c_read(); uint8_t mmz = i2c_read();
                mx = (float)((int32_t)((mmx << 8) | mlx) - 32768);
                my = (float)((int32_t)((mmy << 8) | mly) - 32768);
                mz = (float)((int32_t)((mmz << 8) | mlz) - 32768);
            }
        }

        // --- 5. MAHONY FILTER CALCULATION ---
        float axf = ax / 16384.0f, ayf = ay / 16384.0f, azf = az / 16384.0f;
        float gxf = gx * 0.00875f * DEG2RAD, gyf = gy * 0.00875f * DEG2RAD, gzf = gz * 0.00875f * DEG2RAD;

        float norm_a = sqrtf(axf*axf + ayf*ayf + azf*azf);
        if(norm_a > 0.7f && norm_a < 1.3f) {
            axf/=norm_a; ayf/=norm_a; azf/=norm_a;
            float vx = 2*(q[1]*q[3] - q[0]*q[2]);
            float vy = 2*(q[0]*q[1] + q[2]*q[3]);
            float vz = q[0]*q[0] - q[1]*q[1] - q[2]*q[2] + q[3]*q[3];
            float ex = (ayf*vz - azf*vy), ey = (azf*vx - axf*vz), ez = (axf*vy - ayf*vx);
            exInt += ex * Ki; eyInt += ey * Ki; ezInt += ez * Ki;
            gxf += Kp*ex + exInt; gyf += Kp*ey + eyInt; gzf += Kp*ez + ezInt;
        }

        // Quaternion Integration
        float qDot0 = 0.5f * (-q[1]*gxf - q[2]*gyf - q[3]*gzf);
        float qDot1 = 0.5f * ( q[0]*gxf + q[2]*gzf - q[3]*gyf);
        float qDot2 = 0.5f * ( q[0]*gyf - q[1]*gzf + q[3]*gxf);
        float qDot3 = 0.5f * ( q[0]*gzf + q[1]*gyf - q[2]*gxf);
        q[0] += qDot0*dt; q[1] += qDot1*dt; q[2] += qDot2*dt; q[3] += qDot3*dt;
        normalize_quat();

        // --- 6. EULER CONVERSION & TRANSMISSION ---
        float roll  = atan2f(2*(q[0]*q[1] + q[2]*q[3]), 1 - 2*(q[1]*q[1] + q[2]*q[2])) * RAD2DEG;
        float pitch = asinf(2*(q[0]*q[2] - q[3]*q[1])) * RAD2DEG;
        float yaw   = atan2f(2*(q[0]*q[3] + q[1]*q[2]), 1 - 2*(q[2]*q[2] + q[3]*q[3])) * RAD2DEG;

        // Use \r\n to prevent the staircase effect in terminal
        sprintf(msg_out, "<%.2f,%.2f,%.2f>\r\n", roll, pitch, yaw);
        uart2_print(msg_out); 

        // PC Monitor Output (UART0)
        //printf("<%.2f,%.2f,%.2f>\r\n", roll, pitch, yaw);

        for (volatile int i = 0; i < 150000; i++); 
    }
}
